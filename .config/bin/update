gum spin --spinner globe --title "ūüĆ≥ nvim-treesitter updating" -- nvim --headless -c TSUpdate +qa
echo "\n" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüĆ≥ nvim-treesitter updated"

gum spin --spinner globe --title "ūüćĽ brew updating" -- brew update >>/tmp/u-$NOW.txt
echo "\n" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüćĽ brew updated"

set -l OUTDATED (brew outdated)
echo $OUTDATED >>/tmp/u-$NOW.txt

if test -n "$OUTDATED"
    gum spin --spinner globe --title "ūüćĽ brew upgrading" -- brew upgrade >>/tmp/u-$NOW.txt
    echo "\n" >>/tmp/u-$NOW.txt
    echo "‚úÖ ūüćĽ brew upgraded"

    gum spin --spinner globe --title "ūüćĽ brew cleaning up" -- brew cleanup --prune=all >>/tmp/u-$NOW.txt
    echo "\n" >>/tmp/u-$NOW.txt
    echo "‚úÖ ūüćĽ brew cleaned up"
else
    echo "No outdated brew packages" >>/tmp/u-$NOW.txt
end

gum spin --spinner globe --title "ūüćĽ brew doctoring" -- brew doctor >>/tmp/u-$NOW.txt
echo "\n" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüćĽ brew doctored"

gum spin --spinner globe --title "ūüćé mas upgrading" -- mas upgrade >>/tmp/u-$NOW.txt
echo "\n" >>/tmp/u-$NOW.txt
echo "‚úÖ ūüćé mas upgraded"

gum spin --spinner globe --title "ūüß∂ fabric upgrading" -- go install github.com/danielmiessler/fabric/cmd/fabric@latest >>/tmp/u-$NOW.txt
