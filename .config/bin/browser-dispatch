#!/usr/bin/env bash

# Map GitHub "org/repo" -> local repo directory
declare -A REPO_DIRS=(
  ["Nutiliti/nutiliti"]="$HOME/c/nu"
  ["joshmedeski/joshmedeski.com"]="$HOME/c/joshmedeski_com"
  ["joshmedeski/sesh"]="$HOME/c/sesh"
)

# Map GitHub "org/repo" -> branch prefix for new worktrees (e.g. "jam" -> "jam/123-1")
declare -A REPO_BRANCH_PREFIXES=(
  ["nutiliti/nutiliti"]="jam"
)

# Map GitHub "org/repo" -> worktree base directory (optional).
# Relative paths are resolved from the repo root; absolute paths are used as-is.
declare -A REPO_WORKTREE_DIRS=(
  ["Nutiliti/nutiliti"]=".wk"
  ["joshmedeski/joshmedeski.com"]="w"
)

# Map GitHub "org/repo" -> sesh setup command to run on new worktree (optional)
declare -A REPO_SETUP_CMDS=(
  ["Nutiliti/nutiliti"]="nu_setup"
  ["joshmedeski/joshmedeski.com"]="pnpm i"
)

github_worktree() {
  local org="$1"
  local repo="$2"
  local kind="$3"
  local number="$4"
  local repo_key="$org/$repo"
  local repo_dir="${REPO_DIRS[$repo_key]}"

  if [[ -z "$repo_dir" ]]; then
    echo "No local directory mapped for $repo_key. Add it to REPO_DIRS in $0."
    exit 1
  fi

  local branch_prefix="${REPO_BRANCH_PREFIXES[$repo_key]}"
  local worktree_base="${REPO_WORKTREE_DIRS[$repo_key]}"
  local setup_cmd="${REPO_SETUP_CMDS[$repo_key]}"
  local issue
  local use_pr_checkout=0

  if [[ "$kind" == "pull" ]]; then
    local pr_author me
    pr_author=$(gh pr view "$number" --repo "$repo_key" --json author --jq '.author.login' 2>/dev/null)
    me=$(gh api user --jq '.login' 2>/dev/null)

    if [[ -n "$pr_author" && "$pr_author" != "$me" ]]; then
      issue="$number"
      use_pr_checkout=1
      echo "PR #$number authored by @$pr_author; checking out PR branch"
    else
      issue=$(gh pr view "$number" --repo "$repo_key" --json closingIssuesReferences --jq '.closingIssuesReferences[0].number' 2>/dev/null)
      if [[ -z "$issue" ]]; then
        issue=$(gh pr view "$number" --repo "$repo_key" --json title,body --jq '"\(.title)\n\(.body)"' 2>/dev/null | grep -oE '#[0-9]+' | head -n1 | tr -d '#')
      fi
      if [[ -n "$issue" ]]; then
        echo "PR #$number references issue #$issue"
      else
        issue="$number"
        use_pr_checkout=1
        echo "PR #$number has no issue reference; checking out PR branch"
      fi
    fi
  else
    issue="$number"
  fi

  echo "Issue #$issue in $repo_key"

  cd "$repo_dir" || exit 1

  local worktree_root
  if [[ -z "$worktree_base" ]]; then
    worktree_root="$repo_dir/.wk"
  elif [[ "$worktree_base" = /* ]]; then
    worktree_root="$worktree_base"
  else
    worktree_root="$repo_dir/$worktree_base"
  fi

  local target="$worktree_root/$issue"

  if [[ -d "$target" ]]; then
    if [[ "$use_pr_checkout" == "1" ]]; then
      cd "$target" || exit 1
      gh pr checkout "$number" --repo "$repo_key"
      git pull --ff-only 2>/dev/null || true
    fi
    sesh connect --switch "$target"
  else
    mkdir -p "$worktree_root"
    if [[ "$use_pr_checkout" == "1" ]]; then
      git worktree add --detach "$target" origin/main
      cd "$target" || exit 1
      gh pr checkout "$number" --repo "$repo_key"
    else
      local branch_name
      if [[ -n "$branch_prefix" ]]; then
        branch_name="$branch_prefix/$issue-1"
      else
        branch_name="$issue"
      fi
      git worktree add "$target" -b "$branch_name" --no-track origin/main
      cd "$target" || exit 1
    fi
    if [[ -n "$setup_cmd" ]]; then
      sesh connect --switch --command "$setup_cmd" .
    else
      sesh connect --switch .
    fi
  fi

  # When invoked from osascript there is no $TMUX, so sesh's --switch has no
  # client to act on. Explicitly switch the active tmux client.
  local tmux_client session
  tmux_client=$(tmux list-clients -F '#{client_name}' 2>/dev/null | head -n1)
  if [[ -n "$tmux_client" ]]; then
    session=$(tmux list-sessions -F '#{session_name} #{session_path}' 2>/dev/null \
      | awk -v p="$target" '$2 == p {print $1; exit}')
    if [[ -n "$session" ]]; then
      tmux switch-client -c "$tmux_client" -t "$session"
    fi
  fi

  osascript -e 'tell application "Wezterm" to activate'
}

URL=$(osascript -e 'tell application "Helium" to return URL of active tab of front window' 2>/dev/null)
if [[ -z "$URL" ]]; then
  echo "Failed to get URL from Helium browser."
  exit 1
fi

case "$URL" in
  https://github.com/*/*/issues/[0-9]*|https://github.com/*/*/pull/[0-9]*)
    if [[ "$URL" =~ ^https://github\.com/([^/]+)/([^/]+)/(issues|pull)/([0-9]+) ]]; then
      github_worktree "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}" "${BASH_REMATCH[3]}" "${BASH_REMATCH[4]}"
    fi
    ;;
  *)
    echo "No action for URL: $URL"
    exit 1
    ;;
esac
